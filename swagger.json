  "components": {
    "schemas": {
      "CrearCitaDTO": {
        "required": [
          "clienteId",
          "estado",
          "fechaHora",
          "propiedadId"
        ],
        "type": "object",
        "properties": {
          "fechaHora": {
            "type": "string",
            "format": "date-time"
          },
          "estado": {
            "minLength": 1,
            "pattern": "Agendada|Realizada|Cancelada|Pospuesta",
            "type": "string"
          },
          "clienteId": {
            "type": "integer",
            "format": "int32"
          },
          "propiedadId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CrearClienteDTO": {
        "required": [
          "apellido",
          "dni",
          "email",
          "nombre",
          "telefono",
          "tipoCliente"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "apellido": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "dni": {
            "maximum": 99999999,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "email": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "telefono": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "tipoCliente": {
            "minLength": 1,
            "pattern": "Propietario|Inquilino|Comprador|Vendedor",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CrearContratoCliente": {
        "required": [
          "clienteId",
          "contratoId",
          "rol"
        ],
        "type": "object",
        "properties": {
          "contratoId": {
            "type": "integer",
            "format": "int32"
          },
          "clienteId": {
            "type": "integer",
            "format": "int32"
          },
